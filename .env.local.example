# Google Earth Engine service-account credentials.
# Paste the FULL JSON of the service-account key as a single line (or use quoting).
# Get this file from: Google Cloud Console → IAM & Admin → Service Accounts →
#   tropenbos-service-account → ⋮ Manage keys → Add key → Create new key → JSON.
# Also register the service account at https://signup.earthengine.google.com/#!/service_accounts
#
# Do NOT commit the real .env.local — it is gitignored by default.
#
# Example (the value must be valid JSON on one line):
# GEE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"tropenbosghana","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"tropenbos-service-account@tropenbosghana.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

GEE_SERVICE_ACCOUNT_KEY=
